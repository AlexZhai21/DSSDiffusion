    {
      "cell_type": "code",
      "source": [
        "# Model Inference\n",
        "\n",
        "# Load base pipeline\n",
        "pipe = StableDiffusionPipeline.from_pretrained(\n",
        "    CFG[\"base_model\"],\n",
        "    torch_dtype=torch.float16,\n",
        "    safety_checker=None,\n",
        ").to(device)\n",
        "\n",
        "# Use DPM-Solver++ = much faster than DDPM and better quality than DDIM\n",
        "pipe.scheduler = DPMSolverMultistepScheduler.from_config(pipe.scheduler.config)\n",
        "\n",
        "# Inject LoRA weights\n",
        "pipe.unet = PeftModel.from_pretrained(pipe.unet, CFG[\"output_dir\"])\n",
        "pipe.unet = pipe.unet.merge_and_unload()  # merges LoRA into base weights permanently for faster inference\n",
        "\n",
        "# Memory optimizations for T4 GPU by processing one head at a time\n",
        "pipe.enable_attention_slicing()\n",
        "\n",
        "# Naruto related prompts\n",
        "prompts = [\n",
        "    \"a ninja with silver hair and a headband, standing in a forest\",\n",
        "    \"a young girl with pink hair and green eyes, smiling\",\n",
        "    \"a fierce warrior with red markings on his face, dramatic lighting\",\n",
        "]\n",
        "\n",
        "negative_prompt = \"blurry, low quality, bad anatomy, extra limbs, watermark, realistic, photograph\"\n",
        "\n",
        "# Grid of test images\n",
        "results = []\n",
        "for prompt in prompts:\n",
        "    image = pipe(\n",
        "        prompt=prompt,\n",
        "        #cross_attention_kwargs={\"scale\": 1.0} # only use if you want to scale the weight that the LoRA weight matrices affect each denoising step or want to add multiple LoRAs with different scales, effective weights applied on forward pass are W_effective = W_base + \"scale\" * (alpha/rank) * W_B @ W_A - don't use if already using merge_and_unload() to collapse LoRA weights into base weights permantently for fatser inference, use instead if want more flexibility and control\n",
        "        negative_prompt=negative_prompt,\n",
        "        num_inference_steps=20,   # DPM-Solver++ is good at 20 steps\n",
        "        guidance_scale=7.5,\n",
        "        height=512,\n",
        "        width=512,\n",
        "        generator=torch.Generator(device=device).manual_seed(42),  # reproducible\n",
        "    ).images[0]\n",
        "    results.append(image)\n",
        "\n",
        "# Display all results inline\n",
        "def make_grid(images, cols=3):\n",
        "    w, h = images[0].size\n",
        "    grid = PILImage.new(\"RGB\", (w * cols, h * ((len(images) + cols - 1) // cols)))\n",
        "    for i, img in enumerate(images):\n",
        "        grid.paste(img, ((i % cols) * w, (i // cols) * h))\n",
        "    return grid\n",
        "\n",
        "grid = make_grid(results)\n",
        "grid.save(\"./outputs/naruto_results.png\")\n",
        "grid   # displays inline in Colab"
      ],
