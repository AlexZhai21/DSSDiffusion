            "/tmp/ipykernel_1236/2265791080.py:30: FutureWarning: `torch.cuda.amp.GradScaler(args...)` is deprecated. Please use `torch.amp.GradScaler('cuda', args...)` instead.\n",
            "  scaler = torch.cuda.amp.GradScaler()   # for fp16 training - scales gradients up before backward pass and back down before update to prevent underflow with limited numerical range\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "torch.manual_seed(CFG[\"seed\"])\n",
        "global_step = 0\n",
        "\n",
        "print(f\"Starting training: {CFG['num_train_epochs']} epochs, {num_update_steps} total steps\")\n",
        "\n",
        "unet.train()\n",
        "\n",
        "for epoch in range(CFG[\"num_train_epochs\"]):\n",
        "    epoch_loss = 0.0\n",
        "    optimizer.zero_grad()\n",
        "\n",
        "    for step, batch in enumerate(dataloader):\n",
        "        pixel_values = batch[\"pixel_values\"].to(device, dtype=weight_dtype) # normalized float tensor of PIL image\n",
        "        input_ids    = batch[\"input_ids\"].to(device) # indexes to tokens in CLIP vocabulary = fixed lookup table of around 49k entries\n",
        "\n",
        "        # 1. Encode/compress images to latent space\n",
        "        with torch.no_grad():\n",
        "            latents = vae.encode(pixel_values).latent_dist.sample()\n",
        "            latents = latents * vae.config.scaling_factor   # SD-specific scaling\n",
        "\n",
        "        # 2. Sample random noise and timesteps\n",
        "        noise = torch.randn_like(latents)\n",
        "        bsz = latents.shape[0]\n",
        "        timesteps = torch.randint(\n",
        "            0, noise_scheduler.config.num_train_timesteps,\n",
        "            (bsz,), device=device\n",
        "        ).long()\n",
        "\n",
        "        # 3. Add noise to latents (forward diffusion)\n",
        "        noisy_latents = noise_scheduler.add_noise(latents, noise, timesteps)\n",
        "\n",
        "        # 4. Encode text prompts\n",
        "        with torch.no_grad():\n",
        "            encoder_hidden_states = text_encoder(input_ids)[0]\n",
        "\n",
        "        # 5. Predict the noise with LoRA-patched UNet\n",
        "        with torch.cuda.amp.autocast(enabled=(CFG[\"mixed_precision\"] == \"fp16\")):\n",
        "            noise_pred = unet(noisy_latents, timesteps, encoder_hidden_states).sample\n",
        "\n",
        "            # Loss: MSE between predicted and actual noise (simple diffusion objective)\n",
        "            loss = torch.nn.functional.mse_loss(\n",
        "                noise_pred.float(), noise.float(), reduction=\"mean\"\n",
        "            )\n",
        "            loss = loss / CFG[\"gradient_accumulation_steps\"]\n",
        "\n",
        "        scaler.scale(loss).backward()\n",
        "        epoch_loss += loss.item()\n",
        "\n",
        "        # Gradient accumulation step\n",
        "        if (step + 1) % CFG[\"gradient_accumulation_steps\"] == 0:\n",
        "            scaler.unscale_(optimizer)\n",
        "            torch.nn.utils.clip_grad_norm_(unet.parameters(), 1.0)\n",
        "            scaler.step(optimizer)\n",
        "            scaler.update()\n",
        "            lr_scheduler.step()\n",
        "            optimizer.zero_grad()\n",
        "            global_step += 1\n",
        "\n",
        "            # Periodic checkpoint\n",
        "            if CFG[\"save_steps\"] > 0 and global_step % CFG[\"save_steps\"] == 0:\n",
        "                ckpt_dir = os.path.join(CFG[\"output_dir\"], f\"checkpoint-{global_step}\")\n",
        "                unet.save_pretrained(ckpt_dir)\n",
        "                print(f\"  Saved checkpoint to {ckpt_dir}\")\n",
        "\n",
        "    avg_loss = epoch_loss / len(dataloader)\n",
        "    print(f\"Epoch {epoch+1}/{CFG['num_train_epochs']} | loss: {avg_loss:.4f} | lr: {lr_scheduler.get_last_lr()[0]:.2e}\")\n",
        "\n",
        "print(\"Training complete!\")"
