    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "import math\n",
        "import torch\n",
        "import itertools\n",
        "from pathlib import Path\n",
        "from PIL import Image\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from torchvision import transforms\n",
        "\n",
        "from diffusers import (\n",
        "    StableDiffusionPipeline,\n",
        "    DDPMScheduler,\n",
        "    AutoencoderKL,\n",
        "    UNet2DConditionModel,\n",
        "    DPMSolverMultistepScheduler,\n",
        ")\n",
        "from diffusers.optimization import get_scheduler\n",
        "from transformers import CLIPTextModel, CLIPTokenizer\n",
        "from peft import LoraConfig, get_peft_model, PeftModel\n",
        "from datasets import load_dataset\n",
        "from PIL import Image as PILImage\n",
        "\n",
        "from huggingface_hub import login"
      ],
      "metadata": {
        "id": "zL3QrB0YwF5m"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from google.colab import userdata\n",
        "login(userdata.get(\"HF_TOKEN\"))"
      ],
      "metadata": {
        "id": "U9wuk1iCwK4W"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "CFG = {\n",
        "    # Model\n",
        "    \"base_model\":        \"runwayml/stable-diffusion-v1-5\",\n",
        "\n",
        "    # Dataset\n",
        "    \"dataset_name\":      \"lambdalabs/naruto-blip-captions\",\n",
        "    \"caption_column\":    \"text\",\n",
        "\n",
        "    # Output\n",
        "    \"output_dir\":        \"./outputs\",\n",
        "\n",
        "    # Training\n",
        "    \"resolution\":        512,       # 512x512 is SD 1.5 model's native resolution; could use 768 for higher resolution/quality but would use signficantly more VRAM\n",
        "    \"train_batch_size\":  1,         # number of images processed per forward pass/training step; should probably keep at 1 when using free T4 GPU to save memory\n",
        "    \"gradient_accumulation_steps\": 4,   # effective batch size = how many forward passes/training steps you accumulate gradients before before updating weights - mathematically equivalent to a batch size of 4 but only using the memory of batch size 1 as set above\n",
        "    \"num_train_epochs\":  50,        # number of full passes through the dataset (one epoch = all images seen once) in training process\n",
        "    \"learning_rate\":     1e-4, # controls how large each weight update is - 1e-4 is a good default for LoRA because you're updating way fewer parameters than full fine-tuning\n",
        "    \"lr_scheduler\":      \"cosine\", # learning reate scheduler - controls how learning rate changes over training - \"cosine\" smoothly decays towards 0 following a cosine curve\n",
        "    \"lr_warmup_steps\":   100,      # learning rate starts at 0 and linearly ramps up to the initial \"learning_rate\" value (1e-4 here)\" over \"lr_warmup_steps value (100 here) number of steps before the learning rate scheduler decay starts (cosine here) - prevents large destructive updates in first few steps when LoRA weights are randomly initialized and noisy\n",
        "    \"mixed_precision\":   \"fp16\",    # uses 16-bit floats instead of 32-bits for most computations to reduce VRAM issue roughly in half and speed up matrix multiplications (use \"no\" if issues)\n",
        "    \"seed\":              42,       # fixed random number generator state for reproducibility (weight initialization, noise samples, data shuffling order)\n",
        "\n",
        "    # LoRA Configuation\n",
        "    # Original weight matrix = W (d_in, d_out) - lower-rank LoRA matrices: W_A (r, d_in), W_B (d_out, r) - where r = \"lora_rank\" hyperparameter set below\n",
        "    \"lora_rank\":         8,   # r in LoRA = inner dimension of the two low-rank matrices - lower rank = fewer parameters and faster training vs highr ranking = more capacity but approaches full fine-tuning (some integer between 4-16 is typical)\n",
        "    \"lora_alpha\":        16,   # scaling factor applied to the LoRA output = affects how much influence LoRA updates have: (\"lora_alpha\" / \"lora_rank\") * W_B @ W_A; usually set as 2x the \"lora_rank\" = 2 x 8 = 16 in this case\n",
        "    \"lora_dropout\":      0.1, # randomly zeroes \"lora_dropout\" value (0.1 here) proportion of LoRA activations as a form of regularization to reduce overfittingm, especially on small datasets\n",
        "    \"lora_target_modules\": [\"to_q\", \"to_k\", \"to_v\", \"to_out.0\"], # specifies which layers inside the UNet architecture get LoRA adapters injected: to_q = projects image features to queries, to_k = projects text embeddings to keys (in cross_attention blocks, still image features projected in self_attention blocks), to_v = projects text embeddings to values (in cross_attention blocks, still image features projected in self_attention blocks), to_out = linearly projects attention output back to d_model shape and adds to residual update stream\n",
        "    \"save_steps\":        0,   # Saves a checkpoint of the LoRA weights every N steps/gradient updates (set to 0 = only save at end)\n",
        "    \"lora_weight_init\":  \"gaussian\",  # specifies how the LoRA W_A and W_B weight matrices are initialized at the start of training: - Gaussian = W_A has random values sampled from a Gaussian N(0, sigma^2) distribution, W_B is initialized as all 0s - such that LoRA starts as an identity operation that contributes nothing at initialization so the model is still pure SD 1.5, both matrices gradually pushed away from this starting point over training\n",
        "}\n",
        "\n",
        "os.makedirs(CFG[\"output_dir\"], exist_ok=True)\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(f\"Using device: {device}\")\n",
        "print(f\"VRAM available: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB\")"
      ],
