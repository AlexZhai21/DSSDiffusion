    {
      "cell_type": "code",
      "source": [
        "dataset = HFDataset(hf_dataset, tokenizer, CFG[\"resolution\"])\n",
        "\n",
        "dataloader = DataLoader(\n",
        "    dataset,\n",
        "    batch_size=CFG[\"train_batch_size\"],\n",
        "    shuffle=True,\n",
        "    num_workers=2,\n",
        "    pin_memory=True,\n",
        ")\n",
        "\n",
        "optimizer = torch.optim.AdamW(\n",
        "    unet.parameters(),       # only LoRA paramaters are trainable\n",
        "    lr=CFG[\"learning_rate\"], # the base lr that gets scaled per-parameter\n",
        "    betas=(0.9, 0.999),     # β₁=0.9 (momentum), β₂=0.999 (variance tracking\n",
        "    weight_decay=1e-2,      # adds a small constant pull toward zero on every weight at every step, so only weights weights with a strong enough gradient signal can be large — preventing the model from memorizing training data by growing arbitrarily large weights.\n",
        "    eps=1e-8,               # ε, small episolon constant added that prevents division by zero when √v is tiny\n",
        ")\n",
        "\n",
        "num_update_steps = math.ceil(\n",
        "    len(dataloader) / CFG[\"gradient_accumulation_steps\"]\n",
        ") * CFG[\"num_train_epochs\"]\n",
        "\n",
        "lr_scheduler = get_scheduler(\n",
        "    CFG[\"lr_scheduler\"],\n",
        "    optimizer=optimizer,\n",
        "    num_warmup_steps=CFG[\"lr_warmup_steps\"],\n",
        "    num_training_steps=num_update_steps,\n",
        ")\n",
        "\n",
        "scaler = torch.cuda.amp.GradScaler()   # for fp16 training - scales gradients up before backward pass and back down before update to prevent underflow with limited numerical range"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "IEQkFEDo1GI-",
